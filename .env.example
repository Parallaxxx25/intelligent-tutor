# =============================================================================
# Intelligent Agentic Tutoring System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# --- LLM ---
GOOGLE_API_KEY=[GEMINI_API_KEY]
OPENROUTER_API_KEY=[OPENROUTER_API_KEY]

# --- Observability ---
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-key-here
LANGCHAIN_TRACING=true
LANGCHAIN_PROJECT=intelligent-tutor
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Databases ---
POSTGRES_URL=postgresql+asyncpg://tutor:tutor_pass@localhost:5432/tutor_db
POSTGRES_URL_SYNC=postgresql://tutor:tutor_pass@localhost:5432/tutor_db
REDIS_URL=redis://localhost:6379/0

# --- Code Execution ---
CODE_EXEC_TIMEOUT=5
CODE_EXEC_MAX_MEMORY_MB=256

# --- Application ---
ENV=development
DEBUG=true
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
